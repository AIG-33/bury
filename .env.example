# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) — primary channel for automated notifications ---
# Optional in dev (falls back to console.log).
RESEND_API_KEY=
RESEND_FROM=Bury Tennis <noreply@example.com>

# --- WhatsApp Business API (planned for Phase 2) ---
# WhatsApp is the primary contact channel in PL. Currently we only use wa.me
# click-to-chat links (no API needed). For automated notifications we'll wire
# Twilio or Meta Business Cloud API later — placeholders below for that.
WHATSAPP_PROVIDER=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

# --- Telegram bot (optional secondary messenger) ---
# Disabled when empty. Used only for users who prefer Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Cron (used by /api/cron) ---
CRON_SECRET=

# --- Observability — optional ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
